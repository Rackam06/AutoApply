# ─────────────────────────────────────────────────────────────────────────────
# AutoApply – Environment Configuration
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Gmail Credentials ────────────────────────────────────────────────────────
# Use a Gmail App Password (NOT your real password).
# How to create one: https://support.google.com/accounts/answer/185833
MY_EMAIL=your.email@gmail.com
MY_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ── Your Details (used in email signatures) ──────────────────────────────────
APPLICANT_NAME=Jane Doe
APPLICANT_PHONE=+1 234 567 890
APPLICANT_WEBSITE=https://www.janedoe.com
APPLICANT_LINKEDIN=https://linkedin.com/in/janedoe

# ── CV Files ─────────────────────────────────────────────────────────────────
# Paths relative to the project root. Create a docs/ folder and put your CVs there.
CV_FILE_FR=docs/CV_French.pdf
CV_FILE_EN=docs/CV_English.pdf

# ── Email Templates ──────────────────────────────────────────────────────────
# Placeholders: {company_name} and {signature}
# Use \n for line breaks inside the .env value (they are converted automatically).

# French template (used when Country == "France")
EMAIL_SUBJECT_FR=Candidature Spontanée – Data Scientist / FinTech – {company_name}
EMAIL_BODY_FR=Bonjour,\n\nPermettez-moi de vous adresser ma candidature spontanée au sein de {company_name}.\n\nPassionné(e) par la data science et la FinTech, je serais ravi(e) de contribuer à vos projets.\n\nJe me tiens disponible pour un entretien à votre convenance.\n\nCordialement,\n{signature}

# English template (used for all other countries)
EMAIL_SUBJECT_EN=Internship Application – Data Scientist / FinTech – {company_name}
EMAIL_BODY_EN=Dear Hiring Manager,\n\nI am writing to express my interest in an internship at {company_name}.\n\nI am passionate about data science and FinTech, and would love the opportunity to contribute to your team.\n\nPlease find my CV attached. I am happy to discuss further at your convenience.\n\nBest regards,\n{signature}
